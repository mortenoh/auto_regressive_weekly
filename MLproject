name: "auto_regressive_weekly"
uv_env: pyproject.toml
required_covariates:
  - rainfall
  - mean_temperature
  - population
# Any covariate named in a run's additional_continuous_covariates is fed to the
# network as an extra feature (on top of the required three above).
allow_free_additional_continuous_covariates: true
entry_points:
  train:
    parameters:
      train_data: str
      model: str
      model_config: str
    command: "python train.py {train_data} {model} --config {model_config}"
  predict:
    parameters:
      model: str
      historic_data: str
      future_data: str
      out_file: str
    command: "python predict.py {model} {historic_data} {future_data} {out_file}"
supported_period_type: 'week'
min_prediction_length: 1
max_prediction_length: 12
# Tunable knobs, surfaced to a run's user_option_values. Defaults are the weekly
# configuration (52-week context, 12-week horizon). The architecture is persisted
# in the trained model, so predict needs no configuration.
user_options:
  n_iter:
    title: Training epochs per ensemble member
    type: integer
    default: 1000
  context_length:
    title: Weeks of history read as context
    type: integer
    default: 52
  n_ensemble:
    title: Deep-ensemble members (seed-varied; pooled at predict time)
    type: integer
    default: 5
  learning_rate:
    title: Adam learning rate
    type: number
    default: 0.00001
  prediction_length:
    title: Forecast horizon (weeks) the model is trained for
    type: integer
    default: 12
  cell:
    title: Recurrent cell type
    type: string
    enum: [gru, simple]
    default: gru
  rnn_features:
    title: Hidden width of the encoder/decoder cells
    type: integer
    default: 16
  head_features:
    title: Hidden width of the output head
    type: integer
    default: 24
  rnn_layers:
    title: Number of stacked encoder/decoder RNN layers
    type: integer
    default: 1
  recursive_decode:
    title: Feed each forecast step's predicted mean back as the next step's input
    type: boolean
    default: false
  dropout_rate:
    title: Dropout probability in the preprocess stage
    type: number
    default: 0.2
  input_dropout_rate:
    title: Feature-dropout probability on the input covariates
    type: number
    default: 0.0
meta_data:
  display_name: 'Weekly Deep Auto Regressive'
  description: "An experimental deep learning model based on an RNN architecture, focusing on predictions based on auto-regressive time series data."
  author: "Knut Rand"
  organization: "HISP Centre, University of Oslo"
  organization_logo_url: "https://landportal.org/sites/default/files/2024-03/university_of_oslo_logo.png"
  contact_email: "knut.rand@dhis2.org"
  citation_info: 'Rand, Knut. 2025. "Weekly Deep Auto Regressive model". HISP Centre, University of Oslo. https://dhis2-chap.github.io/chap-core/external_models/overview_of_supported_models.html'
